{
    "layer": "top",
    "position": "top",
    "height": 10,
    "margin": 0,
    "padding": 0,

    "modules-left": ["niri/workspaces", "niri/window"],
    "modules-center": ["custom/clock"],
    "modules-right": ["custom/temp", "custom/brightness", "pulseaudio", "custom/netmon", "network", "custom/usb", "battery", "tray", "niri/language", "custom/power"],

    "niri/workspaces": {
        "all-outputs": false,         // if true - show workspaces from all monitors
        "disable-scroll": true,
        "format": "{index} {icon}",
        "format-icons": {
            //"urgent": "оШЂ",
            //"focused": "оШЂ",
            "default": ""
        }
    },

    "niri/window": {
        "format": "{}",
        "max-length": 80,
        "rewrite": {
           "(.*)": "$1",
           "vim(.*)": "оШЂ $1",
           "nvim(.*)": "оШЂ $1",
           "ranger(.*)": " пБЉ  ranger"
        }
    },
    "niri/language": {
        "format" : "{short}"
    },
    //"niri/taskbar": {
    //    "format": ""
    //},    

    "custom/temp": {
        "exec": "cat /tmp/wlsunset_label 2>/dev/null || echo 'рЯЦ•пЄП 5000K'",
        "interval": 1,
        "on-click": "~/.config/waybar/temp_cycle.sh",
        "tooltip": "–Я–µ—А–µ–Ї–ї—О—З–Є—В—М —В–µ–Љ–њ–µ—А–∞—В—Г—А—Г (5000K / 4500K / 6500K)"
    },

    "custom/brightness": {
        "exec": "cat /tmp/lg_brightness_label 2>/dev/null || echo '   50%'",
        "interval": 1,
        "on-click": "~/.config/waybar/brightness_cycle.sh",
        "tooltip": "–ѓ—А–Ї–Њ—Б—В—М –Љ–Њ–љ–Є—В–Њ—А–∞ LG"
    },


    "custom/netmon": {
      "format": "{icon}",
      "format-icons": ["у±ЂЛ"],
      "on-click": "alacritty -t network_monitor -e bmon"
    },

    "custom/netmon": {
      "format": "{icon}",
      "format-icons": ["у±ЂЛ"],
      "on-click": "alacritty -t network_monitor -e bmon"
    },
    
    "custom/usb": {
      "format": "{icon}",
      "format-icons": ["пКЗ"],
      //"on-click": "kitty --title watch_lsblk -e watch lsblk"
      "on-click": "alacritty -t watch_lsblk -e watch lsblk"
    },
    "custom/logo": {
      "format": "{icon}",
      "format-icons": ["оШЯ"]
    },

    "network": {
        "format-wifi": "пЗЂ  {essid} ({signalStrength}%)",
        "format-ethernet": "пЮЦ  {ipaddr}/{cidr}",
        "tooltip-format": "пЮЦ  {ifname} via {gwaddr}",
        "format-linked": "пЮЦ  {ifname} (No IP)",
        "format-disconnected": "вЪ†  Disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}",
        "format-charging": "{capacity}% пЗ¶",
        "format-plugged": "{capacity}% пЗ¶",
        "format-alt": "{time} {icon}",

        "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"]
    },

    "custom/clock": {
        "exec": "date +'%a %d %b %H:%M:%S'",
        "interval":1,
        //"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "on-click": "zenity --calendar"
    },
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },

    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": " {icon} {volume}% {format_source}",
        "format-bluetooth": "{volume}% {icon}пКФ {format_source}",
        "format-bluetooth-muted": "{icon}пКФ {format_source}",
        "format-muted": "пС¶  {format_source}",
        "format-source": "пД∞ {volume}%",
        "format-source-muted": "пД± ",
        "format-icons": {
            "headphone": "пА•",
            "hands-free": "пЦР",
            "headset": "пЦР",
            "phone": "пВХ",
            "portable": "пВХ",
            "car": "пЖє",
            "default": ["пА¶"]
        },
        "on-click": "pavucontrol"
    },
    "custom/power": {
      "format": "{icon}",
      "format-icons": ["вПї"],
      "on-click": "$(if zenity --question --text 'Power off'; then systemctl poweroff; fi)"
    }

}

